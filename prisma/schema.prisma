  visit_records visit_records @relation(fields: [visit_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model visit_records {
  id                       String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointment_id           String?                    @db.Uuid
  client_id                String?                    @db.Uuid
  patient_id               String?                    @db.Uuid
  staff_id                 String?                    @db.Uuid
  visit_date               DateTime                   @db.Date
  weight_kg                Decimal?                   @db.Decimal(5, 2)
  temperature_c            Decimal?                   @db.Decimal(4, 1)
  heart_rate_bpm           Int?
  body_condition_score     Int?
  history                  String?
  clinical_examination     String?
  diagnosis                String?
  treatment                Json?                      @default("[]")
  hep                      Json?                      @default("[]")
  internal_notes           String?
  client_notes             String?
  plan                     String?
  created_at               DateTime?                  @default(now()) @db.Timestamp(6)
  updated_at               DateTime?                  @default(now()) @db.Timestamp(6)
  visit_number             String?                    @unique
  respiratory_rate_bpm     Int?
  invoices                 invoices[]
  patient_external_records patient_external_records[]
  visit_measurements       visit_measurements[]
  appointments             appointments?              @relation(fields: [appointment_id], references: [id], onUpdate: NoAction)
  clients                  clients?                   @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  patients                 patients?                  @relation(fields: [patient_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                    users?                     @relation(fields: [staff_id], references: [id], onUpdate: NoAction)

  @@index([appointment_id], map: "idx_visit_records_appt")
  @@index([client_id], map: "idx_visit_records_client")
  @@index([visit_date(sort: Desc)], map: "idx_visit_records_date")
  @@index([patient_id], map: "idx_visit_records_patient")
}

